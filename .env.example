# EverCare Medical Center - Environment Configurations Example
# Copy this file to '.env' and fill in your details to enable live mode.
# If these variables are not present or remain default, EverCare will 
# automatically operate in high-fidelity Mock LocalStorage mode.

# Firebase Configurations (Required for Live DB and File Storage)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# PayMongo API Configurations (Required for Live Payment Gateway Links)
VITE_PAYMONGO_PUBLIC_KEY=pk_test_YOUR_PAYMONGO_PUBLIC_KEY
VITE_PAYMONGO_SECRET_KEY=sk_test_YOUR_PAYMONGO_SECRET_KEY
